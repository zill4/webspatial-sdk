{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - relaxed for demo */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@webspatial/core-sdk": ["../../packages/core/dist"],
      "@webspatial/react-sdk": ["../../packages/react/dist/default"],
      "@webspatial/react-sdk/*": ["../../packages/react/dist/*"]
    }
  },
  "include": ["src"]
}
